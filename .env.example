NODE_ENV=development
PORT=3000

# Security
# Legacy global key remains supported, but generated API clients are recommended.
API_KEY=
ADMIN_API_KEY=change-this-admin-secret
API_KEY_PEPPER=change-this-stable-random-pepper
DEFAULT_API_CLIENT_RATE_LIMIT_PER_MINUTE=60

# HTTP and CORS
CORS_ORIGIN=*
JSON_BODY_LIMIT=10mb
MEDIA_BODY_LIMIT=50mb

# WhatsApp/Puppeteer
WWEBJS_AUTH_PATH=.wwebjs_auth
PUPPETEER_HEADLESS=true
CHROME_EXECUTABLE_PATH=
SEND_MESSAGE_DELAY_MS=5000
QUEUE_DRIVER=memory
# REDIS_URL=redis://redis:6379
MESSAGE_LOG_STORE_BODY=true
MESSAGE_LOG_BODY_MAX_LENGTH=1000

# Storage
DATA_DIR=data
WEBHOOK_STORE_FILE=data/webhooks.json
WEBHOOK_DELIVERY_LOG_FILE=data/webhook-deliveries.log
API_CLIENT_STORE_FILE=data/api-clients.json
API_USAGE_LOG_FILE=data/api-usage.log
AUDIT_LOG_FILE=data/audit.log
PERSISTENCE_DRIVER=file
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=whatsapp_api
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_SSL=false
RETENTION_API_USAGE_DAYS=90
RETENTION_AUDIT_DAYS=180
RETENTION_WEBHOOK_DELIVERY_DAYS=90
RETENTION_MESSAGE_LOG_DAYS=90
UPLOAD_DIR=uploads

# Webhook
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_RETRY_COUNT=3

# Logging
API_LOG_LEVEL=info
